<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>三大类岩石识别小测（带计时+分析）</title>
<style>
* {margin:0;padding:0;box-sizing:border-box;font-family:"微软雅黑",sans-serif;}
body {
    background: linear-gradient(120deg, #e8f4ff, #fdf2f8);
    padding:15px;
}
.container {
    max-width:720px;
    margin:0 auto;
    background:#fff;
    border-radius:14px;
    padding:20px;
    box-shadow:0 6px 18px rgba(0,0,0,0.08);
}
h2 {
    text-align:center;
    color:#222;
    margin-bottom:10px;
}
.timer {
    text-align:center;
    font-size:20px;
    font-weight:bold;
    color:#d93025;
    background:#fff0f0;
    border-radius:8px;
    padding:8px;
    margin-bottom:15px;
}
.q-item {
    margin:18px 0;
    padding:16px;
    border:1px solid #e5e7eb;
    border-radius:10px;
    background:#fafbfc;
}
.q-title {
    font-weight:bold;
    margin-bottom:10px;
    color:#333;
    line-height:1.5;
}
.option {
    margin:8px 0;
    padding:8px 12px;
    border-radius:6px;
    cursor:pointer;
    transition:background .2s;
}
.option:hover {background:#e8f4ff;}
.btns {
    text-align:center;
    margin:20px 0;
}
button {
    padding:10px 22px;
    border:none;
    border-radius:8px;
    background:#2563eb;
    color:#fff;
    font-size:16px;
    cursor:pointer;
    margin:0 6px;
}
button:hover {background:#1d4ed8;}
#resetBtn {background:#6b7280;}
#resetBtn:hover {background:#4b5563;}
.result {
    margin-top:20px;
    padding:18px;
    border-radius:10px;
    background:#f0f7ff;
    display:none;
}
.result h3 {
    margin-bottom:12px;
    color:#1e3a8a;
}
.analysis, .suggest {
    margin-top:10px;
    line-height:1.7;
}
</style>
</head>
<body>
<div class="container">
    <h2>三大类岩石识别小测</h2>
    <div class="timer" id="timer">剩余时间：60秒</div>

    <div id="quizBox"></div>

    <div class="btns">
        <button id="submitBtn">提交答卷</button>
        <button id="resetBtn">重新答题</button>
    </div>

    <div class="result" id="resultBox">
        <h3>📊 学习分析报告</h3>
        <p id="basic"></p>
        <div class="analysis" id="analysis"></div>
        <div class="suggest" id="suggest"></div>
    </div>
</div>

<script>
// 题库：6道纯文字题，无图
const questionList = [
    {
        title: "1. 颗粒粗、斑点状、坚硬致密，典型侵入岩，属于哪一类岩石？",
        options: ["A. 沉积岩", "B. 岩浆岩", "C. 变质岩"],
        answer: "B",
        knowledge: "花岗岩（侵入岩）→岩浆岩；特征：地下缓慢冷却、颗粒粗、坚硬致密。"
    },
    {
        title: "2. 黑色、多气孔、喷出地表快速冷却形成，属于哪一类岩石？",
        options: ["A. 沉积岩", "B. 岩浆岩", "C. 变质岩"],
        answer: "B",
        knowledge: "玄武岩（喷出岩）→岩浆岩；特征：快速冷却、气孔构造。"
    },
    {
        title: "3. 灰白色、遇稀盐酸冒泡、多形成喀斯特地貌，属于哪一类岩石？",
        options: ["A. 沉积岩", "B. 岩浆岩", "C. 变质岩"],
        answer: "A",
        knowledge: "石灰岩→沉积岩；特征：化学/生物沉积、层理、遇盐酸冒泡。"
    },
    {
        title: "4. 薄层、层理明显、常含化石，属于哪一类岩石？",
        options: ["A. 沉积岩", "B. 岩浆岩", "C. 变质岩"],
        answer: "A",
        knowledge: "页岩→沉积岩；特征：细颗粒沉积、层理构造、常含化石。"
    },
    {
        title: "5. 白色/浅色、质地均匀、由石灰岩变质而成，属于哪一类岩石？",
        options: ["A. 沉积岩", "B. 岩浆岩", "C. 变质岩"],
        answer: "C",
        knowledge: "大理岩→变质岩；特征：石灰岩高温高压变质、重结晶、用于建材。"
    },
    {
        title: "6. 条带状、片理明显、矿物定向排列，属于哪一类岩石？",
        options: ["A. 沉积岩", "B. 岩浆岩", "C. 变质岩"],
        answer: "C",
        knowledge: "片麻岩→变质岩；特征：强烈变质、片理/条带构造。"
    }
];

// 计时
let totalTime = 60;
let timeLeft = totalTime;
let timerEl = document.getElementById('timer');
let timerInterval = null;
let startTime = null;

// 渲染题目
const quizBox = document.getElementById('quizBox');
let userAnswer = {};

function renderQuiz() {
    quizBox.innerHTML = '';
    questionList.forEach((q, idx) => {
        quizBox.innerHTML += `
            <div class="q-item">
                <div class="q-title">${q.title}</div>
                <div class="option"><input type="radio" name="q${idx}" value="A"> ${q.options[0]}</div>
                <div class="option"><input type="radio" name="q${idx}" value="B"> ${q.options[1]}</div>
                <div class="option"><input type="radio" name="q${idx}" value="C"> ${q.options[2]}</div>
            </div>
        `;
    });
    document.getElementById('resultBox').style.display = 'none';
}

function startTimer() {
    clearInterval(timerInterval);
    timeLeft = totalTime;
    updateTimer();
    startTime = Date.now();
    timerInterval = setInterval(() => {
        timeLeft--;
        updateTimer();
        if (timeLeft <= 0) {
            clearInterval(timerInterval);
            alert('时间到，自动交卷！');
            submitQuiz(true);
        }
    }, 1000);
}

function updateTimer() {
    timerEl.textContent = `剩余时间：${timeLeft}秒`;
    timerEl.style.color = timeLeft <= 10 ? '#d93025' : '#222';
}

function submitQuiz(auto = false) {
    clearInterval(timerInterval);
    const endTime = Date.now();
    const used = Math.round((endTime - startTime) / 1000);

    let right = 0;
    let wrongArr = [];
    let allAnswered = true;

    questionList.forEach((q, idx) => {
        const sel = document.querySelector(`input[name="q${idx}"]:checked`);
        if (!sel) {
            allAnswered = false;
            return;
        }
        const val = sel.value;
        userAnswer[idx] = val;
        if (val === q.answer) right++;
        else wrongArr.push({ qno: idx + 1, know: q.knowledge });
    });

    if (!auto && !allAnswered) {
        alert('请完成全部题目！');
        return;
    }

    const total = questionList.length;
    const rate = (right / total * 100).toFixed(1);

    // 基础信息
    document.getElementById('basic').innerHTML =
        `⏱️ 用时：${used}秒 / 共${totalTime}秒<br>✅ 答对：${right}/${total}题<br>📈 正确率：<strong>${rate}%</strong>`;

    // 错题解析
    let analysis = '';
    if (wrongArr.length > 0) {
        analysis = '<strong>❌ 错题解析：</strong><br>';
        wrongArr.forEach(item => {
            analysis += `第${item.qno}题：${item.know}<br>`;
        });
    } else {
        analysis = '🎉 全部答对，岩石识别能力优秀！';
    }
    document.getElementById('analysis').innerHTML = analysis;

    // 分层学习建议
    let suggest = '';
    if (rate >= 85) {
        suggest = `🌟 优秀！用时${used}秒、正确率${rate}%。你已熟练掌握三大类岩石的典型特征与分类。建议：拓展岩石圈物质循环、岩石与地貌关系，挑战野外实景识别视频任务。`;
    } else if (rate >= 60) {
        suggest = `📚 良好！用时${used}秒、正确率${rate}%。对典型岩石识别基本掌握，但易混淆沉积岩与变质岩特征。建议：回看微课重点——沉积岩（层理/化石）、变质岩（片理/条带）；完成班级交流区野外识别视频任务，强化实践。`;
    } else {
        suggest = `⚠️ 基础待加强！用时${used}秒、正确率${rate}%。对三大类岩石成因与典型特征掌握不足。建议：重学微课核心知识点，熟记三类岩石关键区别；先完成岩石特征对比表，再做二次刷题；尽快提交野外识别岩石视频，从实景观察建立直观认识。`;
    }
    document.getElementById('suggest').innerHTML = `<strong>💡 学习建议：</strong><br>${suggest}`;

    document.getElementById('resultBox').style.display = 'block';
}

// 按钮事件
document.getElementById('submitBtn').addEventListener('click', () => submitQuiz());
document.getElementById('resetBtn').addEventListener('click', () => {
    renderQuiz();
    userAnswer = {};
    startTimer();
});

// 初始化
renderQuiz();
startTimer();
</script>
</body>
</html>
